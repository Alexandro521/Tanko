    "axios": "1.18.1",
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "cheerio": "1.2.0",
    "gradient-string": "3.0.0",
    "ora": "9.4.1",
    "pdfkit": "0.19.1",
