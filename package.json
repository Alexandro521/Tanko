{
  "name": "tanko",
  "version": "2.0.4",
  "type": "module",
  "description": "Una herramienta para leer y descargar mangas desde la terminal",
  "main": "dist/index.js",
  "keywords": [
    "manga",
    "cli",
    "anime",
    "terminal",
    "reader",
    "tools",
    "scraper"
  ],
