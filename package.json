  },
  "bugs": {
    "url": "https://github.com/Alexandro521/Tanko/issues"
  },
  "homepage": "https://github.com/Alexandro521/Tanko#readme",
  "bin": {
    "tanko": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node ./dist/index.js",
